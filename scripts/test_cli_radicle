#!/bin/bash

# Exit immediately if a command exits with a non-zero status.
set -e

echo "--- SCENARIO 2: Testing RIP-X Layout (Default) ---"
echo "Starting Test: $(date)"
echo "======================================================"

# --- Configuration ---
TEST_DIR_RADICLE="test_repo_radicle"
REPO_PATH_RADICLE="$TEST_DIR_RADICLE"
GIT_DIR_RADICLE="$REPO_PATH_RADICLE/.git"
ID_ALIAS_RAD="rad_id_key"
DEVICE_ALIAS_RAD="rad_dev1_key"
PASSPHRASE_ID_RAD="pass_rad_id_123"
PASSPHRASE_DEV_RAD="pass_rad_dev_456"
METADATA_FILE_RAD="metadata_radicle.json"
DEVICE_SEED_FILE_RAD="device1_radicle.seed"

# RIP-X layout is the default — no override flags needed
IDENTITY_REF="refs/rad/id"
IDENTITY_BLOB="radicle-identity.json"
ATTESTATION_PREFIX="refs/keys"
ATTESTATION_BLOB="link-attestation.json"

# Ensure we handle potential CR characters (\r) from windowsy output
CR=$(printf '\r')

# --- Cleanup Function ---
cleanup() {
  echo ""
  echo "--- Cleaning up Scenario 2 ---"
  auths key delete --alias "$ID_ALIAS_RAD" || true
  auths key delete --alias "$DEVICE_ALIAS_RAD" || true
  rm -rf "$TEST_DIR_RADICLE"
  rm -f "$METADATA_FILE_RAD" "$DEVICE_SEED_FILE_RAD"
  echo "Cleanup complete."
}
trap cleanup EXIT HUP INT QUIT TERM

# --- Setup ---
echo ""
echo "--- Setup ---"
rm -rf "$TEST_DIR_RADICLE"
mkdir "$TEST_DIR_RADICLE"
echo '{
  "xyz.radicle.agent": {
    "alias": "rad_tester",
    "controller": ""
  },
  "profile": {
     "name": "Radicle Test User"
  }
}' > "$METADATA_FILE_RAD"
head -c 32 /dev/urandom > "$DEVICE_SEED_FILE_RAD"
echo "Setup complete."

# --- Test Initialization ---
echo ""
echo "--- Testing: id init-did (Default/RIP-X Layout) ---"
echo "$PASSPHRASE_ID_RAD" | auths --repo "$REPO_PATH_RADICLE" id init-did \
  --metadata-file "$METADATA_FILE_RAD" \
  --local-key-alias "$ID_ALIAS_RAD"

# --- Verification ---
echo ""
echo "--- Verifying Initialization ---"
echo "[Verifying] Listing keys..."
auths key list | grep "$ID_ALIAS_RAD"
echo "[Verifying] Showing identity info..."
CONTROLLER_DID_RAD=$(auths --repo "$REPO_PATH_RADICLE" id show 2>/dev/null | grep 'Controller DID:' | awk -F': ' '{print $2}')
echo "[Verification] Controller DID found: [$CONTROLLER_DID_RAD]"
auths --repo "$REPO_PATH_RADICLE" id show 2>/dev/null | grep 'rad_tester'
echo "[Verifying] Checking Git repository structure..."
ls "$GIT_DIR_RADICLE"
echo "[Verifying] git rev-parse --verify '$IDENTITY_REF'..."
git --git-dir="$GIT_DIR_RADICLE" rev-parse --verify "$IDENTITY_REF" > /dev/null
echo "[Verification] Identity ref '$IDENTITY_REF' found and verified."
COMMIT_HASH_RAD=$(git --git-dir="$GIT_DIR_RADICLE" rev-parse "$IDENTITY_REF")
git --git-dir="$GIT_DIR_RADICLE" ls-tree "$COMMIT_HASH_RAD" | grep "$IDENTITY_BLOB"
echo "[Verification] Identity blob '$IDENTITY_BLOB' found."

# --- Test Key Import ---
echo ""
echo "--- Testing: key import ---"
echo "$PASSPHRASE_DEV_RAD" | auths key import \
  --alias "$DEVICE_ALIAS_RAD" \
  --seed-file "$DEVICE_SEED_FILE_RAD" \
  --controller-did "$CONTROLLER_DID_RAD"

# --- Verification ---
echo ""
echo "--- Verifying Key Import ---"
echo "[Verifying] Listing keys..."
auths key list | grep "$ID_ALIAS_RAD"
auths key list | grep "$DEVICE_ALIAS_RAD"

# --- Test Device Link ---
echo ""
echo "--- Testing: device link (Default/RIP-X Layout) ---"
DERIVE_DID_OUTPUT_RAW=$(auths util derive-did --seed-hex $(xxd -p -c 256 "$DEVICE_SEED_FILE_RAD"))
DERIVE_DID_OUTPUT=${DERIVE_DID_OUTPUT_RAW%$CR}
DEVICE_DID_RAD=${DERIVE_DID_OUTPUT##*DID: }
DEVICE_DID_RAD=$(echo "$DEVICE_DID_RAD" | awk '{$1=$1};1')
echo "Debug: Device DID extracted: [$DEVICE_DID_RAD]"
shopt -s extglob
SANITIZED_DID_RAD=${DEVICE_DID_RAD//[^[:alnum:]]/_}
shopt -u extglob
echo "Debug: Sanitized DID for path: [$SANITIZED_DID_RAD]"
if [[ ! "$SANITIZED_DID_RAD" == did_key_z* ]]; then echo "ERROR: Sanitization failed!"; exit 1; fi

echo -e "$PASSPHRASE_DEV_RAD\n$PASSPHRASE_ID_RAD\n$PASSPHRASE_DEV_RAD" | auths --repo "$REPO_PATH_RADICLE" device link \
  --identity-key-alias "$ID_ALIAS_RAD" \
  --device-key-alias "$DEVICE_ALIAS_RAD" \
  --device-did "$DEVICE_DID_RAD" \
  --note "Radicle layout test device"

# --- Verification ---
echo ""
echo "--- Verifying Device Link ---"
echo "[Verifying] Showing devices..."
auths --repo "$REPO_PATH_RADICLE" id show-devices 2>/dev/null | grep "$DEVICE_DID_RAD" | grep "active"
auths --repo "$REPO_PATH_RADICLE" id show-devices 2>/dev/null | grep "Radicle layout test device"
echo "[Verifying] Checking Git repository structure..."
DEVICE_REF_PATH_RAD="${ATTESTATION_PREFIX}/${SANITIZED_DID_RAD}/signatures"
echo "Debug: Calculated Device Ref Path: [$DEVICE_REF_PATH_RAD]"
echo "[Verifying] git rev-parse --verify '$DEVICE_REF_PATH_RAD'..."
git --git-dir="$GIT_DIR_RADICLE" rev-parse --verify "$DEVICE_REF_PATH_RAD" > /dev/null
echo "[Verification] Device ref '$DEVICE_REF_PATH_RAD' found and verified."
DEV_COMMIT_HASH_RAD=$(git --git-dir="$GIT_DIR_RADICLE" rev-parse "$DEVICE_REF_PATH_RAD")
git --git-dir="$GIT_DIR_RADICLE" ls-tree "$DEV_COMMIT_HASH_RAD" | grep "$ATTESTATION_BLOB"
echo "[Verification] Attestation blob '$ATTESTATION_BLOB' found."

# --- Test Device Revoke ---
echo ""
echo "--- Testing: device revoke (Default/RIP-X Layout) ---"
echo "$PASSPHRASE_ID_RAD" | auths --repo "$REPO_PATH_RADICLE" device revoke \
    --identity-key-alias "$ID_ALIAS_RAD" \
    --device-did "$DEVICE_DID_RAD" \
    --note "Revoking radicle test device"

# --- Verification ---
echo ""
echo "--- Verifying Device Revoke ---"
echo "[Verifying] Showing devices (should be empty)..."
if auths --repo "$REPO_PATH_RADICLE" id show-devices 2>/dev/null | grep "$DEVICE_DID_RAD"; then
    echo "ERROR: Revoked device still listed without --include-revoked!"
    exit 1
else
    echo "OK: Revoked device not listed by default."
fi
echo "[Verifying] Showing devices (including revoked)..."
auths --repo "$REPO_PATH_RADICLE" id show-devices --include-revoked 2>/dev/null | grep "$DEVICE_DID_RAD" | grep "revoked"
auths --repo "$REPO_PATH_RADICLE" id show-devices --include-revoked 2>/dev/null | grep "Revoking radicle test device"
echo "[Verifying] git ref '$DEVICE_REF_PATH_RAD' still exists..."
git --git-dir="$GIT_DIR_RADICLE" rev-parse --verify "$DEVICE_REF_PATH_RAD" > /dev/null
echo "[Verification] Device ref '$DEVICE_REF_PATH_RAD' still found and verified after revoke."

echo ""
echo "======================================================"
echo "--- SCENARIO 2: PASSED ---"
echo "Finished Test: $(date)"
